{
	"name": "engine",
	"private": true,
	"workspaces": [
		"apps/*",
		"packages/*",
		"packages/rulesets/*"
	],
	"scripts": {
		"dev:client": "bun run --cwd apps/client dev",
		"dev:server": "bun run --cwd apps/server dev",
		"build": "bun run --cwd apps/client build",
		"start": "bun run --cwd apps/server start",
		"format": "prettier --write ."
	},
	"devDependencies": {
		"prettier": "^3.9.4",
		"prettier-plugin-svelte": "^4.1.1"
	},
	"packageManager": "bun@1.3.14",
	"engines": {
		"bun": ">=1.3.14"
	}
}
